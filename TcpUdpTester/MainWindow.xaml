<Window x:Class="TcpUdpTester.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="NetTest Console" Height="820" Width="1280" MinHeight="600" MinWidth="900"
        Closing="Window_Closing">

    <Window.Resources>
        <Style TargetType="GroupBox">
            <Setter Property="Margin" Value="3"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="10,3"/>
            <Setter Property="Margin" Value="2"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Padding" Value="2,1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="Label">
            <Setter Property="Padding" Value="2,3"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Margin" Value="2"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Margin" Value="2,3"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <DockPanel>

        <!-- ======================================================= -->
        <!-- Menu Bar                                                  -->
        <!-- ======================================================= -->
        <Menu DockPanel.Dock="Top" FontSize="12">
            <MenuItem Header="_ファイル">
                <MenuItem Header="ログをエクスポート(_E)" Command="{Binding ExportCommand}"/>
                <Separator/>
                <MenuItem Header="終了(_X)" Click="MenuItem_Exit"/>
            </MenuItem>
            <MenuItem Header="_表示">
                <MenuItem Header="トラフィックをクリア(_C)" Command="{Binding ClearCommand}"/>
            </MenuItem>
            <MenuItem Header="_ヘルプ">
                <MenuItem Header="バージョン情報(_A)" Click="MenuItem_About"/>
            </MenuItem>
        </Menu>

        <!-- ======================================================= -->
        <!-- Toolbar                                                   -->
        <!-- ======================================================= -->
        <ToolBar DockPanel.Dock="Top" FontSize="11">
            <CheckBox Content="ログ ON/OFF" IsChecked="{Binding LogEnabled}" Margin="4,0"/>
            <Separator/>
            <Label Content="ログフォルダ:" VerticalAlignment="Center"/>
            <TextBox Text="{Binding LogFolder, UpdateSourceTrigger=PropertyChanged}"
                     Width="250" VerticalAlignment="Center"/>
            <Separator/>
            <CheckBox Content="受信検査" IsChecked="{Binding IsSeqCheckEnabled}" Margin="4,0"
                      ToolTip="受信データ末尾の連番を検査し、欠落を検出します"/>
            <Label Content="桁数:" VerticalAlignment="Center"/>
            <TextBox Text="{Binding SeqCheckDigits, UpdateSourceTrigger=PropertyChanged}"
                     Width="35" VerticalAlignment="Center"
                     IsEnabled="{Binding IsSeqCheckEnabled}"
                     ToolTip="末尾連番の桁数 (1〜10)"/>
            <Separator/>
            <CheckBox Content="コールバック" IsChecked="{Binding IsCallbackEnabled}" Margin="4,0"
                      ToolTip="受信したデータをそのまま送信元へ折り返します"/>
            <Separator/>
            <Button Content="クリア" Command="{Binding ClearCommand}"/>
            <Button Content="エクスポート" Command="{Binding ExportCommand}"/>
        </ToolBar>

        <!-- ======================================================= -->
        <!-- Status Bar                                                -->
        <!-- ======================================================= -->
        <StatusBar DockPanel.Dock="Bottom" Height="26" FontSize="11">
            <StatusBarItem>
                <TextBlock Text="{Binding StateText}" FontWeight="Bold" Margin="4,0"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="TX " FontWeight="Bold" Foreground="#1565C0"/>
                    <TextBlock Text="{Binding TxBytes, StringFormat={}{0:N0} B}" Foreground="#1565C0"/>
                    <TextBlock Text="  (" Foreground="#1565C0"/>
                    <TextBlock Text="{Binding TxBps, StringFormat={}{0:N0} bps}" Foreground="#1565C0"/>
                    <TextBlock Text=")" Foreground="#1565C0"/>
                </StackPanel>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="RX " FontWeight="Bold" Foreground="#2E7D32"/>
                    <TextBlock Text="{Binding RxBytes, StringFormat={}{0:N0} B}" Foreground="#2E7D32"/>
                    <TextBlock Text="  (" Foreground="#2E7D32"/>
                    <TextBlock Text="{Binding RxBps, StringFormat={}{0:N0} bps}" Foreground="#2E7D32"/>
                    <TextBlock Text=")" Foreground="#2E7D32"/>
                </StackPanel>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="パケット TX/RX: "/>
                    <TextBlock Text="{Binding TxCount}"/>
                    <TextBlock Text=" / "/>
                    <TextBlock Text="{Binding RxCount}"/>
                </StackPanel>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="エラー: "/>
                    <TextBlock Text="{Binding ErrorCount}" Foreground="Red"/>
                </StackPanel>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <StackPanel Orientation="Horizontal"
                            Visibility="{Binding IsSeqCheckEnabled,
                                Converter={StaticResource BoolToVisibility}}">
                    <TextBlock Text="連番欠落: "/>
                    <TextBlock Text="{Binding SeqGapCount}" Foreground="OrangeRed" FontWeight="Bold"/>
                </StackPanel>
            </StatusBarItem>
        </StatusBar>

        <!-- ======================================================= -->
        <!-- Main Content Area                                         -->
        <!-- ======================================================= -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" MinHeight="200"/>
                <RowDefinition Height="5"/>
                <RowDefinition Height="215" MinHeight="190"/>
            </Grid.RowDefinitions>

            <!-- ===================================================== -->
            <!-- Row 0: Mode Tabs (Connection) + Traffic Monitor        -->
            <!-- ===================================================== -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="280" MinWidth="220"/>
                    <ColumnDefinition Width="5"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left: Mode Tabs -->
                <TabControl Grid.Column="0" SelectedIndex="{Binding SelectedTabIndex}" FontSize="11">

                    <!-- TCP Client -->
                    <TabItem Header="TCP Client">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="4">
                                <GroupBox Header="接続パラメータ">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="85"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Label Grid.Row="0" Grid.Column="0" Content="ホスト:"/>
                                        <TextBox Grid.Row="0" Grid.Column="1"
                                                 Text="{Binding TcpClientVm.Host, UpdateSourceTrigger=PropertyChanged}"/>
                                        <Label Grid.Row="1" Grid.Column="0" Content="ポート:"/>
                                        <TextBox Grid.Row="1" Grid.Column="1"
                                                 Text="{Binding TcpClientVm.Port, UpdateSourceTrigger=PropertyChanged}"/>
                                        <Label Grid.Row="2" Grid.Column="0" Content="チャンク:"/>
                                        <ComboBox Grid.Row="2" Grid.Column="1"
                                                  ItemsSource="{Binding TcpClientVm.ChunkModes}"
                                                  SelectedItem="{Binding TcpClientVm.ChunkMode}"/>
                                        <Label Grid.Row="3" Grid.Column="0" Content="状態:"/>
                                        <TextBlock Grid.Row="3" Grid.Column="1"
                                                   Text="{Binding TcpClientVm.Status}"
                                                   VerticalAlignment="Center" Margin="4,0"
                                                   FontWeight="Bold"/>
                                    </Grid>
                                </GroupBox>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,4">
                                    <Button Content="接続" Command="{Binding TcpClientVm.ConnectCommand}" Width="80"/>
                                    <Button Content="切断" Command="{Binding TcpClientVm.DisconnectCommand}" Width="80"/>
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <!-- TCP Server -->
                    <TabItem Header="TCP Server">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="4">
                                <GroupBox Header="サーバーパラメータ">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="85"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Label Grid.Row="0" Grid.Column="0" Content="バインドIP:"/>
                                        <TextBox Grid.Row="0" Grid.Column="1"
                                                 Text="{Binding TcpServerVm.BindIp, UpdateSourceTrigger=PropertyChanged}"
                                                 ToolTip="空白の場合 0.0.0.0 (全インターフェース)"/>
                                        <Label Grid.Row="1" Grid.Column="0" Content="ポート:"/>
                                        <TextBox Grid.Row="1" Grid.Column="1"
                                                 Text="{Binding TcpServerVm.Port, UpdateSourceTrigger=PropertyChanged}"/>
                                        <Label Grid.Row="2" Grid.Column="0" Content="チャンク:"/>
                                        <ComboBox Grid.Row="2" Grid.Column="1"
                                                  ItemsSource="{Binding TcpServerVm.ChunkModes}"
                                                  SelectedItem="{Binding TcpServerVm.ChunkMode}"/>
                                        <Label Grid.Row="3" Grid.Column="0" Content="状態:"/>
                                        <TextBlock Grid.Row="3" Grid.Column="1"
                                                   Text="{Binding TcpServerVm.Status}"
                                                   VerticalAlignment="Center" Margin="4,0"
                                                   FontWeight="Bold"/>
                                    </Grid>
                                </GroupBox>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,4">
                                    <Button Content="開始" Command="{Binding TcpServerVm.StartCommand}" Width="80"/>
                                    <Button Content="停止" Command="{Binding TcpServerVm.StopCommand}" Width="80"/>
                                </StackPanel>
                                <GroupBox Header="接続セッション">
                                    <StackPanel>
                                        <ListBox ItemsSource="{Binding TcpServerVm.Sessions}"
                                                 SelectedItem="{Binding TcpServerVm.SelectedSession}"
                                                 Height="90" FontFamily="Consolas" FontSize="11"/>
                                        <TextBlock Text="送信ターゲット: 送信パネルのターゲットIDにセッションIDを入力"
                                                   FontSize="10" Foreground="Gray" TextWrapping="Wrap" Margin="2"/>
                                    </StackPanel>
                                </GroupBox>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <!-- UDP -->
                    <TabItem Header="UDP">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="4">
                                <GroupBox Header="UDPパラメータ">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Label Grid.Row="0" Grid.Column="0" Content="ローカルポート:"/>
                                        <TextBox Grid.Row="0" Grid.Column="1"
                                                 Text="{Binding UdpVm.LocalPort, UpdateSourceTrigger=PropertyChanged}"/>
                                        <Label Grid.Row="1" Grid.Column="0" Content="リモートホスト:"/>
                                        <TextBox Grid.Row="1" Grid.Column="1"
                                                 Text="{Binding UdpVm.RemoteHost, UpdateSourceTrigger=PropertyChanged}"/>
                                        <Label Grid.Row="2" Grid.Column="0" Content="リモートポート:"/>
                                        <TextBox Grid.Row="2" Grid.Column="1"
                                                 Text="{Binding UdpVm.RemotePort, UpdateSourceTrigger=PropertyChanged}"/>
                                        <Label Grid.Row="3" Grid.Column="0" Content="状態:"/>
                                        <TextBlock Grid.Row="3" Grid.Column="1"
                                                   Text="{Binding UdpVm.Status}"
                                                   VerticalAlignment="Center" Margin="4,0"
                                                   FontWeight="Bold"/>
                                    </Grid>
                                </GroupBox>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,4">
                                    <Button Content="開始" Command="{Binding UdpVm.StartCommand}" Width="80"/>
                                    <Button Content="停止" Command="{Binding UdpVm.StopCommand}" Width="80"/>
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                </TabControl>

                <!-- Vertical GridSplitter -->
                <GridSplitter Grid.Column="1" Width="5"
                              HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                              Background="#DDD" ResizeDirection="Columns"/>

                <!-- Right: Traffic Monitor -->
                <GroupBox Grid.Column="2" Header="トラフィックモニタ" FontSize="11">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*" MinHeight="80"/>
                            <RowDefinition Height="5"/>
                            <RowDefinition Height="130" MinHeight="80"/>
                        </Grid.RowDefinitions>

                        <!-- Filter Bar -->
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,2">
                            <TextBlock Text="フィルタ:" VerticalAlignment="Center" Margin="4,0"/>
                            <CheckBox Content="TX" IsChecked="{Binding FilterTx}"/>
                            <CheckBox Content="RX" IsChecked="{Binding FilterRx}"/>
                            <CheckBox Content="GAP" IsChecked="{Binding FilterGap}"
                                      Foreground="#BF360C" FontWeight="Bold"
                                      ToolTip="連番欠落エントリの表示/非表示"/>
                            <TextBox Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                                     Width="140" ToolTip="リモート・セッション・ASCIIでフィルタ"/>
                            <TextBlock Text="{Binding FilteredLog.Count, StringFormat={}({0} 件)}"
                                       VerticalAlignment="Center" Margin="6,0" Foreground="Gray" FontSize="10"/>
                        </StackPanel>

                        <!-- Traffic DataGrid -->
                        <DataGrid x:Name="TrafficGrid"
                                  Grid.Row="1"
                                  ItemsSource="{Binding FilteredLog}"
                                  SelectedItem="{Binding SelectedEntry}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserResizeColumns="True"
                                  CanUserSortColumns="False"
                                  SelectionMode="Single"
                                  FontFamily="Consolas"
                                  FontSize="11"
                                  GridLinesVisibility="Horizontal"
                                  HeadersVisibility="Column"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Auto"
                                  EnableRowVirtualization="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="時刻"       Binding="{Binding Time}"      Width="90"/>
                                <DataGridTextColumn Header="方向"       Binding="{Binding Direction}" Width="40">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Direction}" Value="TX">
                                                    <Setter Property="Foreground" Value="#1565C0"/>
                                                    <Setter Property="FontWeight" Value="Bold"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Direction}" Value="RX">
                                                    <Setter Property="Foreground" Value="#2E7D32"/>
                                                    <Setter Property="FontWeight" Value="Bold"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Direction}" Value="GAP">
                                                    <Setter Property="Foreground" Value="#BF360C"/>
                                                    <Setter Property="FontWeight" Value="Bold"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Proto"     Binding="{Binding Protocol}"  Width="45"/>
                                <DataGridTextColumn Header="セッション" Binding="{Binding Session}"  Width="75"/>
                                <DataGridTextColumn Header="リモート"   Binding="{Binding Remote}"   Width="140"/>
                                <DataGridTextColumn Header="Len"       Binding="{Binding Length}"    Width="55"/>
                                <DataGridTextColumn Header="ASCII"     Binding="{Binding AsciiView}" Width="*"/>
                            </DataGrid.Columns>
                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Direction}" Value="TX">
                                            <Setter Property="Background" Value="#EEF2FF"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Direction}" Value="RX">
                                            <Setter Property="Background" Value="#F1F8E9"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Direction}" Value="GAP">
                                            <Setter Property="Background" Value="#FFF3E0"/>
                                            <Setter Property="FontStyle" Value="Italic"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>
                        </DataGrid>

                        <!-- Horizontal splitter between grid and hex dump -->
                        <GridSplitter Grid.Row="2" Height="5" HorizontalAlignment="Stretch"
                                      Background="#DDD" ResizeDirection="Rows"/>

                        <!-- Hex Dump -->
                        <GroupBox Grid.Row="3" Header="Hex ダンプ" Padding="2">
                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Auto">
                                <TextBlock Text="{Binding SelectedEntry.HexDump, FallbackValue=''}"
                                           FontFamily="Consolas" FontSize="11"
                                           TextWrapping="NoWrap"/>
                            </ScrollViewer>
                        </GroupBox>
                    </Grid>
                </GroupBox>
            </Grid>

            <!-- Horizontal GridSplitter between top area and send panel -->
            <GridSplitter Grid.Row="1" Height="5" HorizontalAlignment="Stretch"
                          Background="#DDD" ResizeDirection="Rows"/>

            <!-- ===================================================== -->
            <!-- Row 2: Send Panel                                       -->
            <!-- ===================================================== -->
            <GroupBox Grid.Row="2" Header="送信パネル" FontSize="11">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="5"/>
                        <ColumnDefinition Width="620" MinWidth="500"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left: Input Area -->
                    <Grid Grid.Column="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Mode / Protocol selector bar -->
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,2">
                            <Label Content="入力モード:" VerticalAlignment="Center"/>
                            <ComboBox ItemsSource="{Binding SendVm.SendModes}"
                                      SelectedItem="{Binding SendVm.SendMode}"
                                      Width="70"/>
                            <Separator/>
                            <Label Content="プロトコル:" VerticalAlignment="Center"/>
                            <ComboBox ItemsSource="{Binding SendVm.Protocols}"
                                      SelectedItem="{Binding SendVm.Protocol}"
                                      Width="65"/>
                            <Separator/>
                            <Label Content="ターゲットID:" VerticalAlignment="Center"/>
                            <TextBox Text="{Binding SendVm.TargetId, UpdateSourceTrigger=PropertyChanged}"
                                     Width="90"
                                     ToolTip="TCP Serverのセッションに送る場合はセッションIDを入力。空白でTCPクライアント接続"/>
                        </StackPanel>

                        <!-- Text Input -->
                        <TextBox Grid.Row="1"
                                 Text="{Binding SendVm.TextInput, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True"
                                 FontFamily="Consolas" FontSize="11"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 VerticalContentAlignment="Top"
                                 HorizontalContentAlignment="Left"
                                 Visibility="{Binding SendVm.SendMode,
                                     Converter={StaticResource ModeToVisibility},
                                     ConverterParameter=Text}"/>

                        <!-- Hex Input -->
                        <TextBox Grid.Row="1"
                                 Text="{Binding SendVm.HexInput, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True"
                                 FontFamily="Consolas" FontSize="11"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 VerticalContentAlignment="Top"
                                 HorizontalContentAlignment="Left"
                                 ToolTip="例: 0A 1B 2C  または  0A,1B,2C"
                                 Visibility="{Binding SendVm.SendMode,
                                     Converter={StaticResource ModeToVisibility},
                                     ConverterParameter=Hex}"/>

                        <!-- File Input -->
                        <StackPanel Grid.Row="1"
                                    Visibility="{Binding SendVm.SendMode,
                                        Converter={StaticResource ModeToVisibility},
                                        ConverterParameter=File}"
                                    Margin="4">
                            <StackPanel Orientation="Horizontal">
                                <TextBox Text="{Binding SendVm.FilePath}" Width="320" IsReadOnly="True"/>
                                <Button Content="参照..." Command="{Binding SendVm.BrowseFileCommand}"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Random Input -->
                        <StackPanel Grid.Row="1"
                                    Visibility="{Binding SendVm.SendMode,
                                        Converter={StaticResource ModeToVisibility},
                                        ConverterParameter=Random}"
                                    Margin="4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Label Grid.Row="0" Grid.Column="0" Content="下限(bytes):"/>
                                <TextBox Grid.Row="0" Grid.Column="1"
                                         Text="{Binding SendVm.RandomMinSize, UpdateSourceTrigger=PropertyChanged}"
                                         ToolTip="生成するランダムデータの最小バイト数"/>
                                <Label Grid.Row="1" Grid.Column="0" Content="上限(bytes):"/>
                                <TextBox Grid.Row="1" Grid.Column="1"
                                         Text="{Binding SendVm.RandomMaxSize, UpdateSourceTrigger=PropertyChanged}"
                                         ToolTip="生成するランダムデータの最大バイト数"/>
                            </Grid>
                            <TextBlock Text="ランダムバイト列を生成して送信します (繰り返し時は毎回新規生成)"
                                       FontSize="10" Foreground="Gray" Margin="2,6,2,2" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Grid>

                    <!-- Vertical splitter -->
                    <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"
                                  Background="#DDD" ResizeDirection="Columns"/>

                    <!-- Right: Preset bar + Send Button + 2x2 Options Grid -->
                    <Grid Grid.Column="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Preset bar -->
                        <DockPanel Grid.Row="0" Margin="4,4,4,2" LastChildFill="False">
                            <Label Content="プリセット:" VerticalAlignment="Center" Padding="2,3"/>
                            <ComboBox ItemsSource="{Binding SendVm.Presets}"
                                      SelectedItem="{Binding SendVm.SelectedPreset}"
                                      DisplayMemberPath="Name"
                                      Width="120"/>
                            <Button Content="削除"
                                    Command="{Binding SendVm.DeletePresetCommand}"
                                    Margin="2,0"/>
                            <Separator/>
                            <TextBox Text="{Binding SendVm.NewPresetName, UpdateSourceTrigger=PropertyChanged}"
                                     Width="100" ToolTip="保存するプリセット名"/>
                            <Button Content="保存"
                                    Command="{Binding SendVm.SavePresetCommand}"
                                    Margin="2,0"/>
                        </DockPanel>

                        <!-- Send Button + Stop Button + Status -->
                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="4,2">
                            <Button Content="送 信" Command="{Binding SendVm.SendCommand}"
                                    FontSize="10" FontWeight="Bold" Height="20" Width="90" Margin="4,0"/>
                            <Button Content="停 止" Command="{Binding SendVm.StopCommand}"
                                    FontSize="10" FontWeight="Bold" Height="20" Width="60" Margin="0,0,4,0"
                                    Foreground="Red"/>
                            <TextBlock Text="{Binding SendVm.SendStatus}"
                                       VerticalAlignment="Center"
                                       Foreground="Gray" FontSize="10" Margin="2,0"/>
                        </StackPanel>

                        <!-- 4-column Options Grid (no scroll needed) -->
                        <UniformGrid Grid.Row="2" Rows="1" Columns="4">

                            <!-- 繰り返し送信 -->
                            <GroupBox Header="繰り返し送信" Padding="4,2">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition/>
                                        <RowDefinition/>
                                        <RowDefinition/>
                                    </Grid.RowDefinitions>
                                    <CheckBox Grid.Row="0" Grid.ColumnSpan="2"
                                              Content="繰り返し有効" IsChecked="{Binding SendVm.RepeatEnabled}"/>
                                    <Label Grid.Row="1" Grid.Column="0" Content="回数:"/>
                                    <TextBox Grid.Row="1" Grid.Column="1"
                                             Text="{Binding SendVm.RepeatCount}"
                                             IsEnabled="{Binding SendVm.RepeatEnabled}"/>
                                    <Label Grid.Row="2" Grid.Column="0" Content="間隔(ms):"/>
                                    <TextBox Grid.Row="2" Grid.Column="1"
                                             Text="{Binding SendVm.RepeatIntervalMs}"
                                             IsEnabled="{Binding SendVm.RepeatEnabled}"/>
                                </Grid>
                            </GroupBox>

                            <!-- 分割送信 -->
                            <GroupBox Header="分割送信" Padding="4,2">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition/>
                                        <RowDefinition/>
                                        <RowDefinition/>
                                        <RowDefinition/>
                                    </Grid.RowDefinitions>
                                    <CheckBox Grid.Row="0" Grid.ColumnSpan="2"
                                              Content="分割有効" IsChecked="{Binding SendVm.SplitEnabled}"/>
                                    <Label Grid.Row="1" Grid.Column="0" Content="固定サイズ:"/>
                                    <TextBox Grid.Row="1" Grid.Column="1"
                                             Text="{Binding SendVm.SplitFixedSize}"
                                             IsEnabled="{Binding SendVm.SplitEnabled}"/>
                                    <CheckBox Grid.Row="2" Grid.ColumnSpan="2"
                                              Content="ランダムサイズ"
                                              IsChecked="{Binding SendVm.SplitRandom}"
                                              IsEnabled="{Binding SendVm.SplitEnabled}"/>
                                    <Label Grid.Row="3" Grid.Column="0" Content="遅延(ms):"/>
                                    <TextBox Grid.Row="3" Grid.Column="1"
                                             Text="{Binding SendVm.InterChunkDelayMs}"
                                             IsEnabled="{Binding SendVm.SplitEnabled}"/>
                                </Grid>
                            </GroupBox>

                            <!-- 通信負荷 -->
                            <GroupBox Header="通信負荷" Padding="4,2">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition/>
                                        <RowDefinition/>
                                        <RowDefinition/>
                                    </Grid.RowDefinitions>
                                    <CheckBox Grid.Row="0" Grid.ColumnSpan="2"
                                              Content="負荷モード (繰り返し設定を無視)"
                                              IsChecked="{Binding SendVm.LoadTestEnabled}"/>
                                    <Label Grid.Row="1" Grid.Column="0" Content="期間(秒):"/>
                                    <TextBox Grid.Row="1" Grid.Column="1"
                                             Text="{Binding SendVm.LoadTestDurationSec, UpdateSourceTrigger=PropertyChanged}"
                                             IsEnabled="{Binding SendVm.LoadTestEnabled}"
                                             ToolTip="0=停止ボタンまで継続"/>
                                    <Label Grid.Row="2" Grid.Column="0" Content="目標(Mbps):"/>
                                    <TextBox Grid.Row="2" Grid.Column="1"
                                             Text="{Binding SendVm.LoadTestTargetMbps, UpdateSourceTrigger=PropertyChanged}"
                                             IsEnabled="{Binding SendVm.LoadTestEnabled}"
                                             ToolTip="0=無制限 (可能な限り高速送信)"/>
                                </Grid>
                            </GroupBox>

                            <!-- 連番付与 -->
                            <GroupBox Header="連番付与" Padding="4,2">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition/>
                                        <RowDefinition/>
                                        <RowDefinition/>
                                    </Grid.RowDefinitions>
                                    <CheckBox Grid.Row="0" Grid.ColumnSpan="2"
                                              Content="連番有効 (末尾にASCII連番)"
                                              IsChecked="{Binding SendVm.SeqSuffixEnabled}"/>
                                    <Label Grid.Row="1" Grid.Column="0" Content="桁数:"/>
                                    <TextBox Grid.Row="1" Grid.Column="1"
                                             Text="{Binding SendVm.SeqSuffixDigits, UpdateSourceTrigger=PropertyChanged}"
                                             IsEnabled="{Binding SendVm.SeqSuffixEnabled}"
                                             ToolTip="例: 桁数4 → 0001, 0002, ... (不足時はゼロ埋め)"/>
                                    <Button Grid.Row="2" Grid.ColumnSpan="2"
                                            Content="カウンタリセット"
                                            Command="{Binding SendVm.ResetSeqCounterCommand}"
                                            IsEnabled="{Binding SendVm.SeqSuffixEnabled}"
                                            Padding="6,2" Margin="2,2"/>
                                </Grid>
                            </GroupBox>

                        </UniformGrid>
                    </Grid>
                </Grid>
            </GroupBox>

        </Grid>
    </DockPanel>
</Window>
